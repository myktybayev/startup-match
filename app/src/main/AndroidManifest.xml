<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:name=".StartupMatchApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.StartupMatch"
        tools:targetApi="31">

        <activity
            android:name=".ui.authentication.RolePageActivity"
            android:exported="false"
            android:label="@string/role_page_title" />
        <activity
            android:name=".ui.authentication.RegistrationActivity"
            android:exported="false"
            android:label="@string/registration_title" />
        <activity
            android:name=".ui.home.activity.AddProjectActivity"
            android:exported="false"
            android:label="@string/add_project_title" />
        <activity
            android:name=".ui.home.activity.AddCommandActivity"
            android:exported="false"
            android:label="@string/add_project_title" />
        <activity
            android:name=".ui.home.activity.AddPitchDeckActivity"
            android:exported="false"
            android:label="@string/add_pitch_step_title" />
        <activity
            android:name=".ui.home.activity.AddProjectGithubActivity"
            android:exported="false"
            android:label="@string/home_step_github" />
        <activity
            android:name=".ui.home.activity.AddMvpActivity"
            android:exported="false"
            android:label="@string/home_step_mvp" />
        <activity
            android:name=".ui.home.activity.AddTractionActivity"
            android:exported="false"
            android:label="@string/home_step_traction" />
        <activity
            android:name=".ui.home.activity.CommandListActivity"
            android:exported="false"
            android:label="@string/command_list_title" />


        <activity
            android:name=".ui.onboarding.OnboardingActivity"
            android:exported="true"
            android:label="@string/onboarding_screen1_title" />

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.StartupMatch">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <meta-data
            android:name="preloaded_fonts"
            android:resource="@array/preloaded_fonts" />
    </application>

</manifest>