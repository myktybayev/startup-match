<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/role_top_blue" />
        </shape>
    </item>
    <item android:left="-40dp" android:top="-60dp">
        <shape android:shape="oval">
            <size android:width="220dp" android:height="220dp" />
            <solid android:color="#0FFFFFFF" />
        </shape>
    </item>
    <item android:right="-80dp" android:bottom="20dp">
        <shape android:shape="oval">
            <size android:width="300dp" android:height="300dp" />
            <solid android:color="#0AFFFFFF" />
        </shape>
    </item>
</layer-list>
