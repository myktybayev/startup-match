<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="AddProjectLabel">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">20dp</item>
        <item name="android:fontFamily">@font/inter_semibold</item>
        <item name="android:textColor">#0F1724</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="AddProjectInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">8dp</item>
        <item name="boxBackgroundColor">@android:color/white</item>
        <item name="boxStrokeColor">#14000000</item>
        <item name="boxCornerRadiusTopStart">6dp</item>
        <item name="boxCornerRadiusTopEnd">6dp</item>
        <item name="boxCornerRadiusBottomStart">6dp</item>
        <item name="boxCornerRadiusBottomEnd">6dp</item>
    </style>

    <style name="AddProjectInputSingle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">56dp</item>
        <item name="android:layout_marginTop">8dp</item>
        <item name="android:background">@drawable/bg_add_project_input</item>
        <item name="android:fontFamily">@font/inter_medium</item>
        <item name="android:paddingStart">17dp</item>
        <item name="android:paddingEnd">17dp</item>
        <item name="android:textColor">#0F1724</item>
        <item name="android:textColorHint">#9AA4B2</item>
        <item name="android:textSize">15sp</item>
    </style>

    <style name="AddProjectInputMulti">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">80dp</item>
        <item name="android:layout_marginTop">8dp</item>
        <item name="android:background">@drawable/bg_add_project_input</item>
        <item name="android:fontFamily">@font/inter_medium</item>
        <item name="android:gravity">top|start</item>
        <item name="android:paddingStart">17dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingEnd">17dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="android:textColor">#0F1724</item>
        <item name="android:textColorHint">#9AA4B2</item>
        <item name="android:textSize">15sp</item>
    </style>

    <style name="AddProjectInputBigMulti">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">140dp</item>
        <item name="android:layout_marginTop">8dp</item>
        <item name="android:background">@drawable/bg_add_project_input</item>
        <item name="android:fontFamily">@font/inter_medium</item>
        <item name="android:gravity">top|start</item>
        <item name="android:paddingStart">17dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingEnd">17dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="android:textColor">#0F1724</item>
        <item name="android:textColorHint">#9AA4B2</item>
        <item name="android:textSize">15sp</item>
    </style>

    <style name="Widget.StartupMatch.FilterSheetChip" parent="android:Widget.TextView">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:background">@drawable/bg_filter_sheet_chip</item>
        <item name="android:paddingStart">17dp</item>
        <item name="android:paddingEnd">17dp</item>
        <item name="android:paddingTop">9dp</item>
        <item name="android:paddingBottom">9dp</item>
        <item name="android:fontFamily">@font/inter_medium</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/filter_sheet_chip_text</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
    </style>

</resources>
