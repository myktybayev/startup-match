<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/page_background"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:scrollbars="none"
    tools:context=".ui.сhallenges.ChallengesFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="56dp"
            android:paddingEnd="20dp">

            <TextView
                android:id="@+id/text_challenges_hero"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/inter_bold"
                android:lineSpacingExtra="2dp"
                android:text="@string/challenges_answers_hero_title"
                android:textColor="@color/investor_title"
                android:textSize="18sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/text_my_submissions_empty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="20dp"
            android:fontFamily="@font/inter_medium"
            android:text="@string/challenge_my_submissions_empty"
            android:textColor="@color/investor_text_secondary"
            android:textSize="14sp"
            android:visibility="gone"
            tools:visibility="visible" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_my_submissions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:clipToPadding="false"
            android:nestedScrollingEnabled="false"
            android:overScrollMode="never"
            android:paddingStart="20dp"
            android:paddingEnd="8dp"
            android:visibility="gone"
            tools:listitem="@layout/item_challenge_my_submission"
            tools:visibility="visible" />

<!--        <androidx.recyclerview.widget.RecyclerView-->
<!--            android:id="@+id/recycler_featured_challenges"-->
<!--            android:layout_width="match_parent"-->
<!--            android:layout_height="wrap_content"-->
<!--            android:layout_marginTop="20dp"-->
<!--            android:clipToPadding="false"-->
<!--            android:nestedScrollingEnabled="false"-->
<!--            android:paddingStart="20dp"-->
<!--            android:paddingEnd="20dp"-->
<!--            android:scrollbars="none"-->
<!--            tools:listitem="@layout/item_challenge_featured" />-->

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="28dp"
            android:layout_marginEnd="20dp"
            android:fontFamily="@font/inter_bold"
            android:text="@string/challenges_section_open"
            android:textColor="@color/investor_title"
            android:textSize="20sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="20dp"
            android:background="@drawable/bg_challenge_insight_strip"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="12dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:contentDescription="@string/challenges_sparkle_content_description"
                android:src="@drawable/ic_challenges_sparkle" />

            <TextView
                android:id="@+id/text_challenges_insight"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:fontFamily="@font/inter_medium"
                android:textColor="@color/investor_chip_text"
                android:textSize="14sp"
                tools:text="Сіздің профильге 3 challenge сәйкес келеді" />
        </LinearLayout>

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:clipToPadding="false"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/chip_filter_all"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_challenge_filter_selected"
                    android:clickable="true"
                    android:focusable="true"
                    android:fontFamily="@font/inter_semibold"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="8dp"
                    android:text="@string/challenges_filter_all"
                    android:textColor="@color/white"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/chip_filter_ai"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_challenge_filter_unselected"
                    android:clickable="true"
                    android:focusable="true"
                    android:fontFamily="@font/inter_semibold"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="8dp"
                    android:text="@string/challenges_filter_ai"
                    android:textColor="@color/investor_title"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/chip_filter_mobile"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_challenge_filter_unselected"
                    android:clickable="true"
                    android:focusable="true"
                    android:fontFamily="@font/inter_semibold"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="8dp"
                    android:text="@string/challenges_filter_mobile"
                    android:textColor="@color/investor_title"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/chip_filter_fintech"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_challenge_filter_unselected"
                    android:clickable="true"
                    android:focusable="true"
                    android:fontFamily="@font/inter_semibold"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="8dp"
                    android:text="@string/challenges_filter_fintech"
                    android:textColor="@color/investor_title"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/chip_filter_saas"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_challenge_filter_unselected"
                    android:clickable="true"
                    android:focusable="true"
                    android:fontFamily="@font/inter_semibold"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="8dp"
                    android:text="@string/challenges_filter_saas"
                    android:textColor="@color/investor_title"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/chip_filter_web"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_challenge_filter_unselected"
                    android:clickable="true"
                    android:focusable="true"
                    android:fontFamily="@font/inter_semibold"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="8dp"
                    android:text="@string/challenges_filter_web"
                    android:textColor="@color/investor_title"
                    android:textSize="12sp" />
            </LinearLayout>
        </HorizontalScrollView>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_open_challenges"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="20dp"
            android:layout_marginBottom="40dp"
            android:nestedScrollingEnabled="false"
            android:overScrollMode="never"
            tools:listitem="@layout/item_challenge_open" />
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
