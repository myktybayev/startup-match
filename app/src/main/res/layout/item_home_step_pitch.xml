<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardPitchStep"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:alpha="0.7"
    app:cardCornerRadius="6dp"
    app:cardElevation="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp">

        <FrameLayout
            android:id="@+id/framePitchIcon"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_home_step_icon">

            <ImageView
                android:id="@+id/imagePitchLogo"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:contentDescription="@null"
                android:src="@drawable/home_icon_pitch" />
        </FrameLayout>

        <TextView
            android:id="@+id/textPitchTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:fontFamily="@font/inter_medium"
            android:text="@string/home_step_pitch"
            android:textColor="#9AA4B2"
            android:textSize="15sp" />

        <ImageView
            android:id="@+id/imagePitchStatus"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:contentDescription="@string/home_step_pitch_pending_a11y"
            android:src="@drawable/home_icon_circle_dashed" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
