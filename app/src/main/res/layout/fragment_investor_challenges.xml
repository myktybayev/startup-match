<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/page_background"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:scrollbars="none"
    tools:context=".ui.investor_role.fragments.ChallengesFromInvestorFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="88dp">

        <TextView
            android:id="@+id/text_page_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/inter_bold"
            android:paddingStart="20dp"
            android:paddingTop="56dp"
            android:paddingEnd="20dp"
            android:text="@string/challenges_screen_title"
            android:textColor="@color/investor_title"
            android:textSize="28sp" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_add_challenge"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="20dp"
            android:clickable="true"
            android:focusable="true"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="8dp"
            app:cardElevation="6dp"
            app:strokeColor="#14000000"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="17dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <FrameLayout
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_investor_challenge_hero_icon">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_gravity="center"
                            android:contentDescription="@null"
                            android:src="@drawable/home_icon_plus"
                            app:tint="@color/kvadrat_blue" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/inter_bold"
                            android:text="@string/investor_challenges_hero_title"
                            android:textColor="@color/investor_title"
                            android:textSize="17sp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:fontFamily="@font/inter_medium"
                            android:lineSpacingExtra="2dp"
                            android:text="@string/investor_challenges_hero_subtitle"
                            android:textColor="@color/investor_text_secondary"
                            android:textSize="13sp" />
                    </LinearLayout>
                </LinearLayout>

                <FrameLayout
                    android:id="@+id/button_add_challenge"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_investor_challenge_add_button"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:contentDescription="@string/investor_challenges_add_content_description"
                        android:src="@drawable/home_icon_plus"
                        app:tint="@color/white" />
                </FrameLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="28dp"
            android:layout_marginEnd="20dp"
            android:fontFamily="@font/inter_bold"
            android:text="@string/challenges_section_open"
            android:textColor="@color/investor_title"
            android:textSize="18sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="20dp"
            android:background="@drawable/bg_challenge_insight_strip"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingVertical="12dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:contentDescription="@string/challenges_sparkle_content_description"
                android:src="@drawable/ic_challenges_sparkle" />

            <TextView
                android:id="@+id/text_challenges_insight"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:fontFamily="@font/inter_semibold"
                android:textColor="@color/investor_chip_text"
                android:textSize="13sp"
                tools:text="Сіздің профильге 3 challenge сәйкес келеді" />
        </LinearLayout>

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:clipToPadding="false"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/chip_filter_all"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_challenge_filter_selected"
                    android:clickable="true"
                    android:focusable="true"
                    android:fontFamily="@font/inter_medium"
                    android:paddingHorizontal="17dp"
                    android:paddingVertical="9dp"
                    android:text="@string/challenges_filter_all"
                    android:textColor="@color/white"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/chip_filter_ai"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_challenge_filter_unselected"
                    android:clickable="true"
                    android:focusable="true"
                    android:fontFamily="@font/inter_medium"
                    android:paddingHorizontal="17dp"
                    android:paddingVertical="9dp"
                    android:text="@string/challenges_filter_ai"
                    android:textColor="@color/investor_text_secondary"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/chip_filter_mobile"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_challenge_filter_unselected"
                    android:clickable="true"
                    android:focusable="true"
                    android:fontFamily="@font/inter_medium"
                    android:paddingHorizontal="17dp"
                    android:paddingVertical="9dp"
                    android:text="@string/challenges_filter_mobile"
                    android:textColor="@color/investor_text_secondary"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/chip_filter_fintech"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_challenge_filter_unselected"
                    android:clickable="true"
                    android:focusable="true"
                    android:fontFamily="@font/inter_medium"
                    android:paddingHorizontal="17dp"
                    android:paddingVertical="9dp"
                    android:text="@string/challenges_filter_fintech"
                    android:textColor="@color/investor_text_secondary"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/chip_filter_saas"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_challenge_filter_unselected"
                    android:clickable="true"
                    android:focusable="true"
                    android:fontFamily="@font/inter_medium"
                    android:paddingHorizontal="17dp"
                    android:paddingVertical="9dp"
                    android:text="@string/challenges_filter_saas"
                    android:textColor="@color/investor_text_secondary"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/chip_filter_web"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_challenge_filter_unselected"
                    android:clickable="true"
                    android:focusable="true"
                    android:fontFamily="@font/inter_medium"
                    android:paddingHorizontal="17dp"
                    android:paddingVertical="9dp"
                    android:text="@string/challenges_filter_web"
                    android:textColor="@color/investor_text_secondary"
                    android:textSize="14sp" />
            </LinearLayout>
        </HorizontalScrollView>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_open_challenges"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="20dp"
            android:layout_marginBottom="24dp"
            android:nestedScrollingEnabled="false"
            android:overScrollMode="never"
            tools:listitem="@layout/item_challenge_open" />
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
