<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="20dp"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp"
    app:strokeColor="#14000000"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="21dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <FrameLayout
                android:id="@+id/frame_logo"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_incoming_logo_blue">

                <ImageView
                    android:id="@+id/image_logo_symbol"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_incoming_lightning" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/text_startup_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/inter_bold"
                    android:textColor="@color/investor_title"
                    android:textSize="16sp"
                    tools:text="SmartPay KZ" />

                <TextView
                    android:id="@+id/text_received_time"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:fontFamily="@font/inter_medium"
                    android:textColor="@color/investor_text_secondary"
                    android:textSize="13sp"
                    tools:text="Кеше, 14:30" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@color/investor_incoming_insight_bg"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/inter_bold"
                android:text="@string/incoming_pitch_label_team"
                android:textColor="@color/investor_title"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/text_team_why"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:fontFamily="@font/inter_medium"
                android:lineSpacingExtra="2dp"
                android:textColor="@color/investor_text_secondary"
                android:textSize="14sp"
                tools:text="5 жылдық FinTech…" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:fontFamily="@font/inter_bold"
                android:text="@string/incoming_pitch_label_validation"
                android:textColor="@color/investor_title"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/text_validation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:fontFamily="@font/inter_medium"
                android:lineSpacingExtra="2dp"
                android:textColor="@color/investor_text_secondary"
                android:textSize="14sp"
                tools:text="10 B2B клиент…" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:orientation="vertical"
            android:paddingTop="4dp">

            <LinearLayout
                android:id="@+id/row_pitch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_incoming_resource_row"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="15dp"
                android:paddingVertical="13dp">

                <FrameLayout
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_incoming_row_icon_tile">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:contentDescription="@null"
                        android:src="@drawable/home_icon_pitch"
                        app:tint="@color/kvadrat_blue" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/inter_semibold"
                        android:text="@string/incoming_pitch_row_pitch_title"
                        android:textColor="@color/investor_title"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/text_row_pitch_sub"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:fontFamily="@font/inter_medium"
                        android:textColor="@color/investor_text_secondary"
                        android:textSize="12sp"
                        tools:text="Google Drive сілтемесі" />
                </LinearLayout>

                <ImageView
                    android:id="@+id/image_row_pitch_trail"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_detail_chevron_right"
                    app:tint="@color/investor_text_secondary" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/row_github"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_incoming_resource_row"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="15dp"
                android:paddingVertical="13dp">

                <FrameLayout
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_incoming_row_icon_tile">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:contentDescription="@null"
                        android:src="@drawable/home_icon_github"
                        app:tint="@color/kvadrat_blue" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/inter_semibold"
                        android:text="@string/incoming_pitch_row_github_title"
                        android:textColor="@color/investor_title"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/text_row_github_sub"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:fontFamily="@font/inter_medium"
                        android:textColor="@color/investor_text_secondary"
                        android:textSize="12sp"
                        tools:text="Соңғы жаңарту…" />
                </LinearLayout>

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_detail_chevron_right"
                    app:tint="@color/investor_text_secondary" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/row_mvp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_incoming_resource_row"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="15dp"
                android:paddingVertical="13dp">

                <FrameLayout
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_incoming_row_icon_tile">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_investors_cabinet_globe"
                        app:tint="@color/kvadrat_blue" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/inter_semibold"
                        android:text="@string/incoming_pitch_row_mvp_title"
                        android:textColor="@color/investor_title"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/text_row_mvp_sub"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:fontFamily="@font/inter_medium"
                        android:textColor="@color/investor_text_secondary"
                        android:textSize="12sp"
                        tools:text="Соңғы жаңарту…" />
                </LinearLayout>

                <ImageView
                    android:id="@+id/image_row_mvp_trail"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_visible_exp_btn"
                    app:tint="@color/investor_text_secondary" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/row_traction"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_incoming_resource_row"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="15dp"
                android:paddingVertical="13dp">

                <FrameLayout
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_incoming_row_icon_tile">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_visible_dashboard"
                        app:tint="@color/kvadrat_blue" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/inter_semibold"
                        android:text="@string/incoming_pitch_row_traction_title"
                        android:textColor="@color/investor_title"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/text_row_traction_sub"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:fontFamily="@font/inter_medium"
                        android:textColor="@color/investor_text_secondary"
                        android:textSize="12sp"
                        tools:text="Users: …" />
                </LinearLayout>

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_detail_chevron_right"
                    app:tint="@color/investor_text_secondary" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/button_reject"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="@drawable/bg_incoming_reject_button"
                android:fontFamily="@font/inter_bold"
                android:gravity="center"
                android:text="@string/incoming_pitch_reject"
                android:textColor="@color/investor_incoming_reject_text"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/button_start_chat"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:background="@drawable/bg_incoming_primary_button"
                android:fontFamily="@font/inter_bold"
                android:gravity="center"
                android:text="@string/incoming_pitch_start_chat"
                android:textColor="@color/white"
                android:textSize="15sp" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
