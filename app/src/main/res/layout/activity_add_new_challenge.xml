<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/page_background"
    android:orientation="vertical"
    tools:context=".ui.investor_role.AddNewChallengeActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingTop="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="17dp">

        <FrameLayout
            android:id="@+id/button_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_challenge_detail_circle_back"
            android:clickable="true"
            android:contentDescription="@string/add_new_challenge_back_a11y"
            android:focusable="true">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:importantForAccessibility="no"
                android:src="@drawable/ic_detail_back" />
        </FrameLayout>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="@font/inter_semibold"
            android:gravity="center"
            android:text="@string/add_new_challenge_title"
            android:textColor="@color/investor_title"
            android:textSize="16sp" />

        <View
            android:layout_width="40dp"
            android:layout_height="40dp" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/investor_card_stroke" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/white"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingTop="20dp"
                android:paddingEnd="20dp"
                android:paddingBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_add_challenge_chip_primary"
                        android:fontFamily="@font/inter_semibold"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="8dp"
                        android:text="@string/add_new_challenge_chip_investor"
                        android:textColor="@color/investor_chip_text"
                        android:textSize="13sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/bg_add_challenge_chip_primary"
                        android:fontFamily="@font/inter_semibold"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="8dp"
                        android:text="@string/add_new_challenge_chip_form"
                        android:textColor="@color/investor_chip_text"
                        android:textSize="13sp" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:fontFamily="@font/inter_bold"
                    android:lineSpacingExtra="2dp"
                    android:text="@string/add_new_challenge_hero_title"
                    android:textColor="@color/investor_title"
                    android:textSize="26sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:fontFamily="@font/inter_light"
                    android:lineSpacingExtra="4dp"
                    android:text="@string/add_new_challenge_hero_body"
                    android:textColor="@color/investor_text_secondary"
                    android:textSize="15sp" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/investor_card_stroke" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="16dp"
                android:layout_marginEnd="20dp"
                android:background="@drawable/bg_add_challenge_field"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="15dp">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#14000000"
                    app:strokeWidth="1dp">

                    <ImageView
                        android:id="@+id/investorPhoto"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:contentDescription="@null"
                        android:scaleType="centerCrop"
                        android:src="@drawable/figma_investor_profile_avatar" />
                </com.google.android.material.card.MaterialCardView>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/investorName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/inter_bold"
                            android:textColor="@color/investor_title"
                            android:textSize="15sp"
                            tools:text="@string/add_new_challenge_investor_name" />

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_marginStart="6dp"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_visible_verified"
                            app:tint="@color/kvadrat_blue" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:fontFamily="@font/inter_medium"
                        android:text="@string/add_new_challenge_investor_role"
                        android:textColor="@color/investor_text_secondary"
                        android:textSize="13sp" />
                </LinearLayout>

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_detail_chevron_right"
                    app:tint="@color/investor_text_secondary" />
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="16dp"
                android:layout_marginEnd="20dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp"
                app:strokeColor="#14000000"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="17dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/inter_bold"
                        android:text="@string/add_new_challenge_section_main"
                        android:textColor="@color/investor_title"
                        android:textSize="18sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:fontFamily="@font/inter_light"
                        android:lineSpacingExtra="3dp"
                        android:text="@string/add_new_challenge_section_main_hint"
                        android:textColor="@color/investor_text_secondary"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:fontFamily="@font/inter_semibold"
                        android:text="@string/add_new_challenge_label_title"
                        android:textColor="@color/investor_title"
                        android:textSize="14sp" />

                    <EditText
                        android:id="@+id/edit_challenge_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_add_challenge_field"
                        android:fontFamily="@font/inter_medium"
                        android:hint="@string/add_new_challenge_hint_title"
                        android:inputType="textCapSentences"
                        android:minHeight="48dp"
                        android:padding="15dp"
                        android:textColor="@color/investor_title"
                        android:textColorHint="@color/investor_text_secondary"
                        android:textSize="15sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/inter_semibold"
                                android:text="@string/add_new_challenge_label_deadline"
                                android:textColor="@color/investor_title"
                                android:textSize="14sp" />

                            <LinearLayout
                                android:id="@+id/row_deadline"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:background="@drawable/bg_add_challenge_field"
                                android:clickable="true"
                                android:focusable="true"
                                android:gravity="center_vertical"
                                android:minHeight="48dp"
                                android:orientation="horizontal"
                                android:padding="15dp">

                                <TextView
                                    android:id="@+id/text_deadline_value"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:fontFamily="@font/inter_medium"
                                    android:text="@string/add_new_challenge_deadline_sample"
                                    android:textColor="@color/investor_title"
                                    android:textSize="15sp" />

                                <ImageView
                                    android:layout_width="16dp"
                                    android:layout_height="16dp"
                                    android:contentDescription="@null"
                                    android:src="@drawable/ic_challenges_calendar_small"
                                    app:tint="@color/investor_title" />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:fontFamily="@font/inter_semibold"
                        android:text="@string/add_new_challenge_label_description"
                        android:textColor="@color/investor_title"
                        android:textSize="14sp" />

                    <EditText
                        android:id="@+id/edit_description"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_add_challenge_field"
                        android:fontFamily="@font/inter_medium"
                        android:gravity="top|start"
                        android:hint="@string/add_new_challenge_hint_description"
                        android:inputType="textMultiLine|textCapSentences"
                        android:lineSpacingExtra="3dp"
                        android:minHeight="112dp"
                        android:padding="15dp"
                        android:textColor="@color/investor_title"
                        android:textColorHint="@color/investor_text_secondary"
                        android:textSize="15sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="16dp"
                android:layout_marginEnd="20dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp"
                app:strokeColor="#14000000"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="17dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/inter_bold"
                        android:text="@string/add_new_challenge_section_tags"
                        android:textColor="@color/investor_title"
                        android:textSize="18sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:fontFamily="@font/inter_light"
                        android:lineSpacingExtra="3dp"
                        android:text="@string/add_new_challenge_section_tags_hint"
                        android:textColor="@color/investor_text_secondary"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:fontFamily="@font/inter_semibold"
                        android:text="@string/add_new_challenge_label_tags"
                        android:textColor="@color/investor_title"
                        android:textSize="14sp" />

                    <LinearLayout
                        android:id="@+id/tabLayouts"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/tag_challenge_fintech"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginEnd="8dp"
                                android:layout_marginBottom="8dp"
                                android:background="@drawable/bg_command_tag_pill"
                                android:clickable="true"
                                android:focusable="true"
                                android:fontFamily="@font/inter_semibold"
                                android:paddingHorizontal="12dp"
                                android:paddingVertical="9dp"
                                android:text="@string/add_new_challenge_tag_fintech"
                                android:textColor="@color/investor_title"
                                android:textSize="13sp" />

                            <TextView
                                android:id="@+id/tag_challenge_web"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginEnd="8dp"
                                android:layout_marginBottom="8dp"
                                android:background="@drawable/bg_command_tag_pill"
                                android:clickable="true"
                                android:focusable="true"
                                android:fontFamily="@font/inter_semibold"
                                android:paddingHorizontal="12dp"
                                android:paddingVertical="9dp"
                                android:text="@string/add_new_challenge_tag_web"
                                android:textColor="@color/investor_title"
                                android:textSize="13sp" />

                            <TextView
                                android:id="@+id/tag_challenge_api"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginEnd="8dp"
                                android:layout_marginBottom="8dp"
                                android:background="@drawable/bg_command_tag_pill"
                                android:clickable="true"
                                android:focusable="true"
                                android:fontFamily="@font/inter_semibold"
                                android:paddingHorizontal="12dp"
                                android:paddingVertical="9dp"
                                android:text="@string/add_new_challenge_tag_api"
                                android:textColor="@color/investor_title"
                                android:textSize="13sp" />

                            <TextView
                                android:id="@+id/tag_challenge_b2b"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginEnd="8dp"
                                android:layout_marginBottom="8dp"
                                android:background="@drawable/bg_command_tag_pill"
                                android:clickable="true"
                                android:focusable="true"
                                android:fontFamily="@font/inter_semibold"
                                android:paddingHorizontal="12dp"
                                android:paddingVertical="9dp"
                                android:text="@string/add_new_challenge_tag_b2b"
                                android:textColor="@color/investor_title"
                                android:textSize="13sp" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tag_challenge_payments"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_command_tag_pill"
                            android:clickable="true"
                            android:focusable="true"
                            android:fontFamily="@font/inter_semibold"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="9dp"
                            android:text="@string/add_new_challenge_tag_payments"
                            android:textColor="@color/investor_title"
                            android:textSize="13sp" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:fontFamily="@font/inter_semibold"
                        android:text="@string/add_new_challenge_label_fit"
                        android:textColor="@color/investor_title"
                        android:textSize="14sp" />

                    <EditText
                        android:id="@+id/edit_team_fit"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_add_challenge_field"
                        android:fontFamily="@font/inter_medium"
                        android:gravity="top|start"
                        android:hint="@string/add_new_challenge_hint_team_fit"
                        android:inputType="textCapSentences|textMultiLine"
                        android:minHeight="48dp"
                        android:padding="15dp"
                        android:textColor="@color/investor_title"
                        android:textColorHint="@color/investor_text_secondary"
                        android:textSize="15sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="16dp"
                android:layout_marginEnd="20dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp"
                app:strokeColor="#14000000"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="17dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/inter_bold"
                        android:text="@string/add_new_challenge_section_requirements"
                        android:textColor="@color/investor_title"
                        android:textSize="18sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:fontFamily="@font/inter_light"
                        android:lineSpacingExtra="3dp"
                        android:text="@string/add_new_challenge_section_requirements_hint"
                        android:textColor="@color/investor_text_secondary"
                        android:textSize="14sp" />

                    <LinearLayout
                        android:id="@+id/requirement_list"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="vertical" />

                    <LinearLayout
                        android:id="@+id/row_add_requirement"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:background="@drawable/bg_add_challenge_chip_primary"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="12dp">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:contentDescription="@null"
                            android:src="@drawable/home_icon_plus"
                            app:tint="@color/investor_chip_text" />

                        <TextView
                            android:id="@+id/add_requirement"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:fontFamily="@font/inter_semibold"
                            android:text="@string/add_new_challenge_add_requirement"
                            android:textColor="@color/investor_chip_text"
                            android:textSize="14sp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="16dp"
                android:layout_marginEnd="20dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp"
                app:strokeColor="#14000000"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="17dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/inter_bold"
                        android:text="@string/add_new_challenge_section_reward"
                        android:textColor="@color/investor_title"
                        android:textSize="18sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:fontFamily="@font/inter_light"
                        android:lineSpacingExtra="3dp"
                        android:text="@string/add_new_challenge_section_reward_hint"
                        android:textColor="@color/investor_text_secondary"
                        android:textSize="14sp" />

                    <LinearLayout
                        android:id="@+id/row_reward_investment"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/bg_add_challenge_chip_primary"
                        android:clickable="true"
                        android:focusable="true"
                        android:orientation="horizontal"
                        android:padding="14dp">

                        <FrameLayout
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@drawable/bg_add_challenge_reward_icon">

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_gravity="center"
                                android:contentDescription="@null"
                                android:src="@drawable/ic_investors_cabinet_globe"
                                app:tint="@color/white" />
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/inter_bold"
                                android:text="@string/add_new_challenge_reward_invest_title"
                                android:textColor="@color/investor_title"
                                android:textSize="15sp" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:fontFamily="@font/inter_medium"
                                android:lineSpacingExtra="3dp"
                                android:text="@string/add_new_challenge_reward_invest_body"
                                android:textColor="@color/investor_chip_text"
                                android:textSize="14sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/row_reward_pilot"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/bg_add_challenge_chip_primary"
                        android:clickable="true"
                        android:focusable="true"
                        android:orientation="horizontal"
                        android:padding="14dp">

                        <FrameLayout
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@drawable/bg_add_challenge_reward_icon">

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_gravity="center"
                                android:contentDescription="@null"
                                android:src="@drawable/ic_investors_cabinet_layers"
                                app:tint="@color/white" />
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/inter_bold"
                                android:text="@string/add_new_challenge_reward_pilot_title"
                                android:textColor="@color/investor_title"
