<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F6FBFF">

    <LinearLayout
        android:id="@+id/layoutTopHeader"
        android:layout_width="0dp"
        android:layout_height="78dp"
        android:background="@android:color/white"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingTop="5dp"
        android:paddingEnd="20dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/buttonBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_add_project_back"
            android:padding="8dp"
            android:src="@drawable/add_command_icon_back" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/inter_semibold"
                android:text="@string/add_project_title"
                android:textColor="#0F1724"
                android:textSize="17sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/inter_light"
                android:text="@string/add_project_subtitle"
                android:textColor="#9AA4B2"
                android:textSize="13sp" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layoutSteps"
        android:layout_width="0dp"
        android:layout_height="82dp"
        android:background="@android:color/white"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutTopHeader">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <TextView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="@drawable/bg_add_project_step_active"
                android:fontFamily="@font/inter_semibold"
                android:gravity="center"
                android:text="1"
                android:textColor="@android:color/white"
                android:textSize="13sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:fontFamily="@font/inter_semibold"
                android:text="@string/add_project_step_main"
                android:textColor="#4B7BFF"
                android:textSize="12sp" />
        </LinearLayout>

        <View
            android:layout_width="112dp"
            android:layout_height="2dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:background="#F1F5F9" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <TextView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="@drawable/bg_add_project_step_active"
                android:fontFamily="@font/inter_semibold"
                android:gravity="center"
                android:text="2"
                android:textColor="@android:color/white"
                android:textSize="13sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:fontFamily="@font/inter_semibold"
                android:text="@string/add_project_step_team"
                android:textColor="#4B7BFF"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:paddingStart="20dp"
        android:paddingTop="24dp"
        android:paddingEnd="20dp"
        android:paddingBottom="24dp"
        android:scrollbars="none"
        app:layout_constraintBottom_toTopOf="@id/layoutBottomSave"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutSteps">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="110dp"
                android:background="@drawable/bg_add_command_info"
                android:orientation="horizontal"
                android:padding="16dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginTop="2dp"
                    android:src="@drawable/add_command_icon_info" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:fontFamily="@font/inter_medium"
                    android:text="@string/add_command_info"
                    android:textColor="#10316B"
                    android:textSize="13sp" />
            </LinearLayout>

            <HorizontalScrollView
                android:id="@+id/scrollMembers"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:fillViewport="false"
                android:overScrollMode="never"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/layoutMembersRow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingEnd="4dp" />
            </HorizontalScrollView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp"
                app:strokeColor="#14000000"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="21dp">

                    <TextView
                        android:id="@+id/textMemberTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/inter_semibold"
                        android:textColor="#0F1724"
                        android:textSize="16sp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="13dp"
                        android:background="#14000000" />

                    <TextView
                        style="@style/AddProjectLabel"
                        android:text="@string/add_command_member_avatar" />

                    <ImageView
                        android:id="@+id/imageMemberAvatar"
                        android:layout_width="72dp"
                        android:layout_height="72dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_home_avatar_border"
                        android:clipToOutline="true"
                        android:scaleType="centerCrop"
                        android:src="@drawable/ic_dashboard_black_24dp" />

                    <TextView
                        style="@style/AddProjectLabel"
                        android:text="@string/add_command_member_name" />

                    <EditText
                        android:id="@+id/editMemberName"
                        style="@style/AddProjectInputSingle"
                        android:hint="@string/add_command_member_name_hint"
                        android:inputType="textPersonName" />

                    <TextView
                        style="@style/AddProjectLabel"
                        android:text="@string/add_command_member_role" />

                    <FrameLayout
                        android:id="@+id/roleDropdownContainer"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_add_project_input"
                        android:paddingStart="17dp"
                        android:paddingEnd="17dp">

                        <Spinner
                            android:id="@+id/spinnerRole"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@android:color/transparent"
                            android:paddingEnd="20dp"
                            android:spinnerMode="dropdown" />
                    </FrameLayout>

                    <TextView
                        style="@style/AddProjectLabel"
                        android:text="@string/add_command_member_experience" />

                    <EditText
                        android:id="@+id/editExperience"
                        style="@style/AddProjectInputMulti"
                        android:hint="@string/add_command_member_experience_hint"
                        android:inputType="textMultiLine" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:fontFamily="@font/inter_semibold"
                        android:text="@string/add_command_member_portfolio"
                        android:textColor="#0F1724"
                        android:textSize="14sp" />

                    <EditText
                        android:id="@+id/editPortfolio"
                        style="@style/AddProjectInputSingle"
                        android:hint="@string/add_command_member_portfolio_hint"
                        android:inputType="textUri" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonAddMember"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="20dp"
                android:backgroundTint="#EAF2FF"
                android:fontFamily="@font/inter_semibold"
                android:text="@string/add_command_add_member"
                android:textAllCaps="false"
                android:textColor="#4B7BFF"
                android:textSize="16sp"
                app:cornerRadius="8dp"
                app:icon="@drawable/add_command_icon_plus"
                app:iconGravity="textStart"
                app:iconPadding="8dp"
                app:iconTint="#4B7BFF"
                app:strokeColor="#4B7BFF"
                app:strokeWidth="1dp" />
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/layoutBottomSave"
        android:layout_width="0dp"
        android:layout_height="89dp"
        android:background="@android:color/white"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingTop="17dp"
        android:paddingEnd="20dp"
        android:paddingBottom="32dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonSaveProject"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:backgroundTint="#4B7BFF"
            android:fontFamily="@font/inter_semibold"
            android:text="@string/add_command_save_project"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            app:cornerRadius="8dp"
            app:icon="@drawable/add_command_icon_check"
            app:iconGravity="textEnd"
            app:iconPadding="8dp"
            app:iconTint="@android:color/white" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
