<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/page_background"
    android:orientation="vertical"
    tools:context=".ui.сhallenges.ChallengeAnswerActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingTop="56dp"
        android:paddingEnd="20dp"
        android:paddingBottom="17dp">

        <FrameLayout
            android:id="@+id/button_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_challenge_detail_circle_back"
            android:clickable="true"
            android:contentDescription="@string/challenge_answer_back_content_description"
            android:focusable="true">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_detail_back" />
        </FrameLayout>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="@font/inter_semibold"
            android:gravity="center"
            android:text="@string/challenge_answer_screen_title"
            android:textColor="@color/investor_title"
            android:textSize="16sp" />

        <View
            android:layout_width="40dp"
            android:layout_height="40dp" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/investor_card_stroke" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="20dp"
                android:layout_marginEnd="20dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp"
                app:strokeColor="@color/investor_card_stroke"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="17dp">

                    <TextView
                        android:id="@+id/text_summary_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/inter_bold"
                        android:textColor="@color/investor_title"
                        android:textSize="16sp"
                        tools:text="B2B төлемдер интеграциясы" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <ImageView
                                android:layout_width="14dp"
                                android:layout_height="14dp"
                                android:contentDescription="@null"
                                android:src="@drawable/ic_challenges_calendar_small" />

                            <TextView
                                android:id="@+id/text_summary_deadline"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="4dp"
                                android:fontFamily="@font/inter_light"
                                android:textColor="@color/investor_text_secondary"
                                android:textSize="13sp"
                                tools:text="20 Қаңтар" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <ImageView
                                android:layout_width="14dp"
                                android:layout_height="14dp"
                                android:contentDescription="@null"
                                android:src="@drawable/ic_detail_meta_tag" />

                            <TextView
                                android:id="@+id/text_summary_categories"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="4dp"
                                android:fontFamily="@font/inter_light"
                                android:textColor="@color/investor_text_secondary"
                                android:textSize="13sp"
                                tools:text="FinTech, Web" />
                        </LinearLayout>
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="13dp"
                        android:background="@color/investor_card_stroke" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="13dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <de.hdodenhof.circleimageview.CircleImageView
                            android:id="@+id/image_summary_investor"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            tools:src="@drawable/figma_investor_avatar_1" />

                        <TextView
                            android:id="@+id/text_summary_investor_name"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:fontFamily="@font/inter_semibold"
                            android:textColor="@color/investor_title"
                            android:textSize="14sp"
                            tools:text="Асқар Есен" />

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_marginStart="4dp"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_detail_verified" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="24dp"
                android:layout_marginEnd="20dp"
                android:fontFamily="@font/inter_semibold"
                android:text="@string/challenge_answer_label_project"
                android:textColor="@color/investor_title"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/text_no_projects"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="8dp"
                android:layout_marginEnd="20dp"
                android:fontFamily="@font/inter_medium"
                android:text="@string/challenge_answer_error_no_projects"
                android:textColor="@color/challenge_prize_text"
                android:textSize="14sp"
                android:visibility="gone" />

            <Spinner
                android:id="@+id/spinner_project"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginStart="20dp"
                android:layout_marginTop="8dp"
                android:layout_marginEnd="20dp"
                android:background="@drawable/bg_challenge_answer_field"
                android:paddingEnd="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="20dp"
                android:layout_marginEnd="20dp"
                android:fontFamily="@font/inter_semibold"
                android:text="@string/challenge_answer_label_why_fit"
                android:textColor="@color/investor_title"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/edit_motivation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="8dp"
                android:layout_marginEnd="20dp"
                android:background="@drawable/bg_challenge_answer_field"
                android:fontFamily="@font/inter_medium"
                android:gravity="top|start"
                android:hint="@string/challenge_answer_hint_why_fit"
                android:inputType="textMultiLine|textCapSentences"
                android:minHeight="120dp"
                android:paddingHorizontal="17dp"
                android:paddingTop="12dp"
                android:paddingBottom="40dp"
                android:textColor="@color/investor_title"
                android:textColorHint="@color/investor_text_secondary"
                android:textSize="15sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="20dp"
                android:layout_marginEnd="20dp"
                android:fontFamily="@font/inter_semibold"
                android:text="@string/challenge_answer_label_pitch"
                android:textColor="@color/investor_title"
                android:textSize="14sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginStart="20dp"
                android:layout_marginTop="8dp"
                android:layout_marginEnd="20dp"
                android:background="@drawable/bg_challenge_answer_field"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_marginStart="17dp"
                    android:contentDescription="@null"
                    android:src="@drawable/add_pitch_icon_link" />

                <EditText
                    android:id="@+id/edit_pitch_link"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:fontFamily="@font/inter_medium"
                    android:hint="@string/challenge_answer_hint_pitch"
                    android:inputType="textUri"
                    android:paddingEnd="17dp"
                    android:textColor="@color/investor_title"
                    android:textColorHint="@color/investor_text_secondary"
                    android:textSize="15sp" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="4dp"
                android:layout_marginEnd="20dp"
                android:fontFamily="@font/inter_light"
                android:text="@string/challenge_answer_pitch_helper"
                android:textColor="@color/investor_text_secondary"
                android:textSize="12sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="20dp"
                android:layout_marginEnd="20dp"
                android:fontFamily="@font/inter_semibold"
                android:text="@string/challenge_answer_label_mvp"
                android:textColor="@color/investor_title"
                android:textSize="14sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginStart="20dp"
                android:layout_marginTop="8dp"
                android:layout_marginEnd="20dp"
                android:background="@drawable/bg_challenge_answer_field"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_marginStart="17dp"
                    android:contentDescription="@null"
                    android:src="@drawable/add_pitch_icon_link" />

                <EditText
                    android:id="@+id/edit_mvp_link"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:fontFamily="@font/inter_medium"
                    android:hint="@string/challenge_answer_hint_mvp"
                    android:inputType="textUri"
                    android:paddingEnd="17dp"
                    android:textColor="@color/investor_title"
                    android:textColorHint="@color/investor_text_secondary"
                    android:textSize="15sp" />
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="32dp">

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/investor_card_stroke" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_submit"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="17dp"
            android:text="@string/challenge_answer_submit"
            android:textColor="@color/white"
            app:backgroundTint="@color/kvadrat_blue"
            app:cornerRadius="6dp"
            app:fontFamily="@font/inter_semibold" />
    </LinearLayout>
</LinearLayout>
