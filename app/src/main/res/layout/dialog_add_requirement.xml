<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="20dp"
    android:paddingTop="16dp"
    android:paddingEnd="20dp"
    android:paddingBottom="8dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="@font/inter_bold"
        android:text="@string/add_new_challenge_dialog_requirement_title"
        android:textColor="@color/investor_title"
        android:textSize="18sp" />

    <EditText
        android:id="@+id/edit_requirement_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_add_challenge_field"
        android:fontFamily="@font/inter_medium"
        android:gravity="top|start"
        android:hint="@string/add_new_challenge_dialog_requirement_hint"
        android:inputType="textMultiLine|textCapSentences"
        android:minHeight="120dp"
        android:padding="15dp"
        android:textColor="@color/investor_title"
        android:textColorHint="@color/investor_text_secondary"
        android:textSize="15sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:gravity="end"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_requirement_cancel"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/dialog_cancel"
            android:textColor="@color/investor_text_secondary"
            app:fontFamily="@font/inter_semibold" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_requirement_save"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="@string/dialog_save"
            android:textColor="@color/white"
            app:backgroundTint="@color/kvadrat_blue"
            app:cornerRadius="6dp"
            app:fontFamily="@font/inter_semibold" />
    </LinearLayout>
</LinearLayout>
